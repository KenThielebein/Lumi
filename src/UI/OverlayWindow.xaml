<Window x:Class="Lumi.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lumi"
        Width="560" Height="260"
        MinWidth="280" MinHeight="72"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Theme-aware chip brushes — updated at runtime via ApplyTheme() -->
        <SolidColorBrush x:Key="ChipActiveFg"   Color="#FFC107"/>
        <SolidColorBrush x:Key="ChipInactiveFg" Color="#80FFFFFF"/>
        <SolidColorBrush x:Key="ChipActiveBg"   Color="#40FFC107"/>
        <SolidColorBrush x:Key="ChipHoverBg"    Color="#20FFFFFF"/>

        <Style x:Key="ModeChip" TargetType="RadioButton">
            <Setter Property="Margin"    Value="3,0"/>
            <Setter Property="Padding"   Value="10,3"/>
            <Setter Property="FontSize"  Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource ChipInactiveFg}"/>
            <Setter Property="Cursor"    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" CornerRadius="10" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource ChipActiveBg}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource ChipHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground"  Value="{DynamicResource ChipActiveFg}"/>
                    <Setter Property="FontWeight"  Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OverlayIconButton" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="Foreground" Value="#D0FFFFFF"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="OverlayToggleButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="Foreground" Value="#D0FFFFFF"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ChipActiveBg}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ChipActiveFg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HistoryNumberButton" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="Foreground" Value="#80FFFFFF"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="MainBorder"
                CornerRadius="36"
                Padding="20,38,48,8"
                Background="#E8000000"
                PreviewMouseLeftButtonDown="MainBorder_PreviewMouseLeftButtonDown">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="4" Opacity="0.5"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: main content -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Modus-Icon (wird ausgeblendet wenn Chips sichtbar) -->
                    <TextBlock x:Name="ModeIcon"
                               Grid.Column="0"
                               Text="💬"
                               FontSize="18"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Visibility="Collapsed"/>

                    <!-- Haupt-Inhalt -->
                    <Grid Grid.Column="1" VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="IdleText"
                                   Grid.Row="0"
                                   Text="Lumi"
                                   Foreground="#80FFFFFF"
                                   FontSize="15"
                                   FontWeight="Light"
                                   VerticalAlignment="Center"/>

                        <StackPanel x:Name="WavePanel"
                                    Grid.Row="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <StackPanel.Resources>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Width"   Value="4"/>
                                    <Setter Property="Fill"    Value="#FF4CAF50"/>
                                    <Setter Property="RadiusX" Value="2"/>
                                    <Setter Property="RadiusY" Value="2"/>
                                    <Setter Property="Margin"  Value="2,0"/>
                                </Style>
                            </StackPanel.Resources>
                            <Rectangle x:Name="Bar1" Height="8"/>
                            <Rectangle x:Name="Bar2" Height="16"/>
                            <Rectangle x:Name="Bar3" Height="24"/>
                            <Rectangle x:Name="Bar4" Height="16"/>
                            <Rectangle x:Name="Bar5" Height="8"/>
                            <Rectangle x:Name="Bar6" Height="20"/>
                            <Rectangle x:Name="Bar7" Height="12"/>
                            <Rectangle x:Name="Bar8" Height="6"/>
                        </StackPanel>

                        <StackPanel x:Name="SpinnerPanel"
                                    Grid.Row="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="ProcessingText"
                                       Text="Verarbeite…"
                                       Foreground="#FFFFFFFF"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <ScrollViewer x:Name="ResultScroll"
                                      Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="Collapsed">
                            <TextBlock x:Name="ResultText"
                                       Foreground="#FFFFFFFF"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"/>
                        </ScrollViewer>

                        <TextBlock x:Name="ErrorText"
                                   Grid.Row="0"
                                   Foreground="#FFFF5252"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>

                        <Grid x:Name="DictationHistoryEditorPanel"
                              Grid.Row="0"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DictationHistoryEditor"
                                     Grid.Column="0"
                                     Padding="8,6"
                                     FontSize="13"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     BorderThickness="1"
                                     BorderBrush="#40FFFFFF"
                                     Background="#24000000"
                                     Foreground="White"
                                     CaretBrush="White"
                                     TextChanged="DictationHistoryEditor_TextChanged"/>
                            <Button x:Name="CopyDictationHistoryButton"
                                    Grid.Column="1"
                                    Width="36"
                                    Margin="6,0,0,0"
                                    Content="📋"
                                    ToolTip="Text in die Zwischenablage kopieren"
                                    BorderThickness="0"
                                    Background="{DynamicResource ChipActiveBg}"
                                    Foreground="{DynamicResource ChipActiveFg}"
                                    Cursor="Hand"
                                    Click="CopyDictationHistoryButton_Click"/>
                            <Button x:Name="LearnDictationCorrectionButton"
                                    Grid.Column="2"
                                    Width="82"
                                    Margin="6,0,0,0"
                                    Content="＋ Lernen"
                                    ToolTip="Diese Korrektur künftig automatisch anwenden"
                                    BorderThickness="0"
                                    Background="{DynamicResource ChipActiveBg}"
                                    Foreground="{DynamicResource ChipActiveFg}"
                                    Cursor="Hand"
                                    Click="LearnDictationCorrectionButton_Click"/>
                        </Grid>

                        <StackPanel x:Name="SuggestionActionsPanel"
                              Grid.Row="2"
                              Orientation="Horizontal"
                              HorizontalAlignment="Right"
                              Margin="0,6,0,0"
                              Visibility="Collapsed">
                            <TextBlock x:Name="SuggestionStatusText"
                                       Foreground="#FF81C784"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Button Content="Abbrechen" Margin="3,0" Padding="8,4"
                                    Click="CancelSuggestionButton_Click"/>
                            <Button Content="Neu" Margin="3,0" Padding="8,4"
                                    Click="RetrySuggestionButton_Click"/>
                            <Button Content="Kopieren" Margin="3,0" Padding="8,4"
                                    Click="CopySuggestionButton_Click"/>
                            <Button Content="Ersetzen ↵" Margin="3,0" Padding="10,4"
                                    Background="{DynamicResource ChipActiveBg}"
                                    Foreground="{DynamicResource ChipActiveFg}"
                                    Click="AcceptSuggestionButton_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Provider-Indikator -->
                    <TextBlock x:Name="ProviderIcon"
                               Visibility="Collapsed"
                               Grid.Column="2"
                               Text="☁"
                               FontSize="15"
                               Foreground="#80FFFFFF"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </Grid>

                <!-- Row 1: Modus-Chips -->
                <StackPanel x:Name="ModeChipsPanel"
                            Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0">
                    <RadioButton x:Name="ChipSuggestion"
                                 Style="{StaticResource ModeChip}"
                                 GroupName="Mode"
                                 Content="✏ Vorschlag"
                                 Click="Chip_Click"
                                 Tag="Suggestion"/>
                    <RadioButton x:Name="ChipDictation"
                                 Style="{StaticResource ModeChip}"
                                 GroupName="Mode"
                                 Content="🎤 Diktat"
                                 IsChecked="True"
                                 Click="Chip_Click"
                                 Tag="Dictation"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock x:Name="VersionText"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Margin="24,0,0,12"
                   Foreground="#60FFFFFF"
                   FontSize="10"
                   Panel.ZIndex="35"/>

        <StackPanel x:Name="DictationHistoryPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,16,24"
                    Panel.ZIndex="35">
            <Button x:Name="DictationHistoryButton1" Style="{StaticResource HistoryNumberButton}" Content="1" Tag="0" IsEnabled="False" Click="DictationHistoryButton_Click"/>
            <Button x:Name="DictationHistoryButton2" Style="{StaticResource HistoryNumberButton}" Content="2" Tag="1" IsEnabled="False" Click="DictationHistoryButton_Click"/>
            <Button x:Name="DictationHistoryButton3" Style="{StaticResource HistoryNumberButton}" Content="3" Tag="2" IsEnabled="False" Click="DictationHistoryButton_Click"/>
            <Button x:Name="DictationHistoryButton4" Style="{StaticResource HistoryNumberButton}" Content="4" Tag="3" IsEnabled="False" Click="DictationHistoryButton_Click"/>
            <Button x:Name="DictationHistoryButton5" Style="{StaticResource HistoryNumberButton}" Content="5" Tag="4" IsEnabled="False" Click="DictationHistoryButton_Click"/>
        </StackPanel>

        <!-- Resize grip -->
        <Border x:Name="ResizeGrip"
                Width="20" Height="20"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="Transparent"
                Cursor="SizeNWSE"
                MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                Panel.ZIndex="30">
            <Path Data="M 2,14 L 14,2 M 6,14 L 14,6 M 10,14 L 14,10"
                  Stroke="#50FFFFFF" StrokeThickness="1.5"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        </Border>

        <StackPanel x:Name="ActionButtonsPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,18,0"
                    Panel.ZIndex="40">
            <Button x:Name="CompactToggleButton"
                    Style="{StaticResource OverlayIconButton}"
                    Content="▾"
                    ToolTip="Pille ein- oder ausklappen"
                    Click="CompactToggleButton_Click"/>
            <ToggleButton x:Name="DictationInsertModeToggle"
                          Style="{StaticResource OverlayToggleButton}"
                          Content="↳"
                          IsChecked="True"
                          ToolTip="Diktat sofort am Cursor einfügen"
                          Click="DictationInsertModeToggle_Click"/>
            <Button x:Name="HandsFreeDictationButton"
                    Style="{StaticResource OverlayIconButton}"
                    Content="🎤"
                    ToolTip="Freihand-Diktat starten"
                    PreviewMouseLeftButtonDown="HandsFreeDictationButton_PreviewMouseLeftButtonDown"
                    Click="HandsFreeDictationButton_Click"/>
            <Button x:Name="SettingsButton"
                    Style="{StaticResource OverlayIconButton}"
                    Content="⚙"
                    ToolTip="Einstellungen"
                    PreviewMouseLeftButtonDown="SettingsButton_PreviewMouseLeftButtonDown"
                    Click="SettingsButton_Click"/>
            <Button x:Name="ExitButton"
                    Style="{StaticResource OverlayIconButton}"
                    Content="×"
                    ToolTip="Lumi beenden"
                    PreviewMouseLeftButtonDown="ExitButton_PreviewMouseLeftButtonDown"
                    Click="ExitButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
