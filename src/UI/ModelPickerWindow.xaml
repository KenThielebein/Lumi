<Window x:Class="Lumi.UI.ModelPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenRouter – Modell auswählen"
        Width="660" Height="580"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        FontFamily="Segoe UI">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Suchfeld -->
            <RowDefinition Height="*"/>      <!-- Liste / Status -->
            <RowDefinition Height="Auto"/>   <!-- Ausgewählt-Zeile -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🔍" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Modell auswählen" FontSize="18" FontWeight="Light" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Suchfeld -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <TextBox x:Name="SearchBox"
                     Background="#2D2D2D" Foreground="White"
                     BorderBrush="#555" BorderThickness="1"
                     Padding="10,8" FontSize="13" CaretBrush="White"
                     TextChanged="SearchBox_TextChanged"/>
            <TextBlock x:Name="Placeholder" Text="Modellname oder ID eingeben…"
                       Foreground="#555" FontSize="13"
                       Margin="12,8,0,0" IsHitTestVisible="False"/>
        </Grid>

        <!-- Ladehinweis -->
        <TextBlock x:Name="StatusText" Grid.Row="2"
                   Text="Modelle werden geladen…"
                   Foreground="#888" FontSize="13"
                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <!-- Modellliste -->
        <ListBox x:Name="ModelsList" Grid.Row="2"
                 Background="#252525" BorderBrush="#444" BorderThickness="1"
                 Visibility="Collapsed"
                 SelectionMode="Single"
                 SelectionChanged="ModelsList_SelectionChanged"
                 MouseDoubleClick="ModelsList_DoubleClick"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="12,9"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#2E2E2E"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3D2F00"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="#2A2A2A"/>
                        </MultiTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Linke Spalte: Name + ID -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="White" TextWrapping="NoWrap"/>
                            <TextBlock Text="{Binding Id}"
                                       FontSize="11" Foreground="#666"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Rechte Spalte: Kontext + Preis -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    Margin="16,0,0,0" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding ContextDisplay}"
                                       FontSize="11" Foreground="#777"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding PriceDisplay}"
                                       FontSize="11" Foreground="#FFC107"
                                       HorizontalAlignment="Right" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Ausgewähltes Modell -->
        <Border x:Name="SelectedPanel" Grid.Row="3"
                Background="#2A2A2A" BorderBrush="#555" BorderThickness="1"
                Margin="0,10,0,0" Padding="12,8"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✓  " Foreground="#4CAF50" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SelectedName" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="SelectedPrice" Grid.Column="1"
                           Foreground="#FFC107" FontSize="12"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="↻ Neu laden" Padding="14,7" Margin="0,0,8,0"
                    Background="#2D2D2D" Foreground="#AAAAAA"
                    BorderThickness="1" BorderBrush="#444" Cursor="Hand"
                    Click="Reload_Click"/>
            <Button Content="Abbrechen" Padding="18,7" Margin="0,0,8,0"
                    Background="#333" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="Cancel_Click"/>
            <Button x:Name="SelectBtn" Content="✓  Auswählen" Padding="18,7"
                    Background="#FFC107" Foreground="Black" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand" IsEnabled="False"
                    Click="Select_Click"/>
        </StackPanel>
    </Grid>
</Window>
